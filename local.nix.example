# local.nix — このマシン固有の設定 (git 管理外)
#
# scripts/setup.sh がこのファイルを雛形に local.nix を生成するので、通常は手で
# 書く必要はない。後から git の名前/メールを変えたいときは local.nix を直接編集し、
# `just switch` で反映する。
#
# 注意: local.nix は .gitignore 済み。just / setup.sh は flake を path: 指定で
# 参照するので、git 追跡の有無に関係なくその場の local.nix が読まれる。消すと
# flake の評価が失敗する。
{
  # WSL 内のログインユーザー。`id -un` の値と一致していること。
  username = "student";
  homeDirectory = "/home/student";

  # git のコミットに刻まれる身元。任意 — この git ブロックごと消してもよい
  # (その場合 commit する時に git が名前を聞いてくるだけ)。GitHub を使うなら
  # GitHub の設定と揃える。
  git = {
    name = "Your Name";
    email = "you@example.com";
  };
}
